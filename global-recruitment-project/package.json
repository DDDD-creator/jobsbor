{
  "name": "global-recruitment-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cd apps/web && next dev",
    "build": "cd apps/web && next build",
    "start": "cd apps/web && next start",
    "lint": "cd apps/web && next lint",
    "db:generate": "cd packages/db && prisma generate",
    "db:migrate": "cd packages/db && prisma migrate dev",
    "db:studio": "cd packages/db && prisma studio"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "next": "15.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "typescript": "5.7.2",
    "@types/node": "22.10.2",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "tailwindcss": "3.4.17",
    "postcss": "8.4.49",
    "autoprefixer": "10.4.20",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.0"
  }
}
