// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(uuid())
  email             String          @unique
  passwordHash      String          @map("password_hash")
  phone             String?
  userType          UserType
  status            UserStatus      @default(PENDING)
  emailVerified     Boolean         @default(false) @map("email_verified")
  phoneVerified     Boolean         @default(false) @map("phone_verified")
  language          String          @default("en")
  timezone          String          @default("UTC")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  lastLogin         DateTime?       @map("last_login")

  profile           Profile?
  companyProfile    CompanyProfile?
  applications      JobApplication[]
  messages          Message[]
  notifications     Notification[]
  analyticsEvents   AnalyticsEvent[]

  @@map("users")
}

enum UserType {
  CANDIDATE
  EMPLOYER
  RECRUITER
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

model Profile {
  id                String          @id @default(uuid())
  userId            String          @unique @map("user_id")
  firstName         String          @map("first_name")
  lastName          String          @map("last_name")
  headline          String?
  summary           String?         @db.Text
  location          String?
  country           String?
  city              String?
  avatarUrl         String?         @map("avatar_url")
  resumeUrl         String?         @map("resume_url")
  portfolioUrl      String?         @map("portfolio_url")
  linkedinUrl       String?         @map("linkedin_url")
  githubUrl         String?         @map("github_url")
  websiteUrl        String?         @map("website_url")
  openToWork        Boolean         @default(false) @map("open_to_work")
  currentSalary     Decimal?        @map("current_salary")
  expectedSalary    Decimal?        @map("expected_salary")
  salaryCurrency    String?         @map("salary_currency")
  yearsOfExperience Int?            @map("years_of_experience")
  educationLevel    EducationLevel? @map("education_level")
  availability      Availability?
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills            CandidateSkill[]
  applications      JobApplication[]
  matches           Match[]

  @@map("profiles")
}

enum EducationLevel {
  HIGH_SCHOOL
  BACHELOR
  MASTER
  PHD
  OTHER
}

enum Availability {
  IMMEDIATELY
  TWO_WEEKS
  ONE_MONTH
  NEGOTIABLE
}

model CompanyProfile {
  id                String          @id @default(uuid())
  userId            String          @unique @map("user_id")
  companyName       String          @map("company_name")
  companySlug       String          @unique @map("company_slug")
  industry          String?
  companySize       CompanySize?    @map("company_size")
  foundedYear       Int?            @map("founded_year")
  headquarters      String?
  website           String?
  description       String?         @db.Text
  logoUrl           String?         @map("logo_url")
  coverImageUrl     String?         @map("cover_image_url")
  companyType       CompanyType?    @map("company_type")
  verified          Boolean         @default(false)
  verificationDate  DateTime?       @map("verification_date")
  socialLinks       Json?           @map("social_links")
  benefits          Json?
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs              Job[]
  subscription      Subscription?

  @@map("company_profiles")
}

enum CompanySize {
  ONE_TO_TEN
  ELEVEN_TO_FIFTY
  FIFTY_ONE_TO_TWO_HUNDRED
  TWO_HUNDRED_ONE_TO_FIVE_HUNDRED
  FIVE_HUNDRED_ONE_TO_THOUSAND
  ONE_THOUSAND_PLUS
}

enum CompanyType {
  STARTUP
  PRIVATE
  PUBLIC
  GOVERNMENT
  NONPROFIT
}

model Job {
  id                String          @id @default(uuid())
  companyId         String          @map("company_id")
  title             String
  slug              String          @unique
  department        String?
  location          String?
  workType          WorkType        @map("work_type")
  employmentType    EmploymentType  @map("employment_type")
  experienceLevel   ExperienceLevel @map("experience_level")
  minSalary         Decimal?        @map("min_salary")
  maxSalary         Decimal?        @map("max_salary")
  salaryCurrency    String?         @map("salary_currency")
  salaryPeriod      SalaryPeriod?   @map("salary_period")
  description       String          @db.Text
  requirements      String[]
  benefits          String[]
  skillsRequired    Json            @map("skills_required")
  status            JobStatus       @default(DRAFT)
  expiresAt         DateTime?       @map("expires_at")
  viewsCount        Int             @default(0) @map("views_count")
  applicationsCount Int             @default(0) @map("applications_count")
  isFeatured        Boolean         @default(false) @map("is_featured")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  publishedAt       DateTime?       @map("published_at")

  company           CompanyProfile  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications      JobApplication[]
  messages          Message[]
  matches           Match[]

  @@index([status, publishedAt])
  @@index([location])
  @@index([workType])
  @@index([employmentType])
  @@index([experienceLevel])
  @@map("jobs")
}

enum WorkType {
  REMOTE
  HYBRID
  ONSITE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum SalaryPeriod {
  HOURLY
  MONTHLY
  YEARLY
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  EXPIRED
}

model JobApplication {
  id                String          @id @default(uuid())
  jobId             String          @map("job_id")
  candidateId       String          @map("candidate_id")
  status            ApplicationStatus @default(APPLIED)
  coverLetter       String?         @map("cover_letter") @db.Text
  resumeUrl         String?         @map("resume_url")
  appliedAt         DateTime        @default(now()) @map("applied_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  interviewDate     DateTime?       @map("interview_date")
  offerAmount       Decimal?        @map("offer_amount")
  notes             String?         @db.Text

  job               Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate         Profile         @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
  @@index([candidateId])
  @@map("job_applications")
}

enum ApplicationStatus {
  APPLIED
  REVIEWED
  SHORTLISTED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model Skill {
  id                String          @id @default(uuid())
  name              String          @unique
  category          String?
  type              SkillType
  parentId          String?         @map("parent_id")
  createdAt         DateTime        @default(now()) @map("created_at")

  candidates        CandidateSkill[]

  @@map("skills")
}

enum SkillType {
  TECHNICAL
  SOFT
  LANGUAGE
  CERTIFICATION
}

model CandidateSkill {
  id                String          @id @default(uuid())
  candidateId       String          @map("candidate_id")
  skillId           String          @map("skill_id")
  proficiency       Proficiency
  yearsUsed         Int?            @map("years_used")
  verified          Boolean         @default(false)
  verificationSource String?        @map("verification_source")
  createdAt         DateTime        @default(now()) @map("created_at")

  candidate         Profile         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill             Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([candidateId, skillId])
  @@map("candidate_skills")
}

enum Proficiency {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Match {
  id                String          @id @default(uuid())
  jobId             String          @map("job_id")
  candidateId       String          @map("candidate_id")
  matchScore        Decimal         @map("match_score") @db.Decimal(5, 2)
  skillMatchScore   Decimal         @map("skill_match_score") @db.Decimal(5, 2)
  experienceScore   Decimal         @map("experience_score") @db.Decimal(5, 2)
  salaryMatchScore  Decimal         @map("salary_match_score") @db.Decimal(5, 2)
  locationScore     Decimal         @map("location_score") @db.Decimal(5, 2)
  algorithmVersion  String          @map("algorithm_version")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  job               Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate         Profile         @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([jobId, matchScore])
  @@index([candidateId, matchScore])
  @@map("matches")
}

model Message {
  id                String          @id @default(uuid())
  senderId          String          @map("sender_id")
  receiverId        String          @map("receiver_id")
  jobId             String?         @map("job_id")
  subject           String?
  body              String          @db.Text
  status            MessageStatus   @default(SENT)
  createdAt         DateTime        @default(now()) @map("created_at")
  readAt            DateTime?       @map("read_at")

  sender            User            @relation(fields: [senderId], references: [id], onDelete: Cascade)
  job               Job?            @relation(fields: [jobId], references: [id])

  @@map("messages")
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  ARCHIVED
}

model Article {
  id                String          @id @default(uuid())
  authorId          String          @map("author_id")
  title             String
  slug              String          @unique
  content           String          @db.Text
  excerpt           String?
  featuredImage     String?         @map("featured_image")
  category          String?
  tags              String[]
  status            ArticleStatus   @default(DRAFT)
  viewsCount        Int             @default(0) @map("views_count")
  likesCount        Int             @default(0) @map("likes_count")
  commentsCount     Int             @default(0) @map("comments_count")
  publishedAt       DateTime?       @map("published_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@map("articles")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Subscription {
  id                String          @id @default(uuid())
  companyId         String          @unique @map("company_id")
  plan              SubscriptionPlan
  status            SubscriptionStatus @default(TRIAL)
  startDate         DateTime        @map("start_date")
  endDate           DateTime?       @map("end_date")
  trialEndDate      DateTime?       @map("trial_end_date")
  maxJobs           Int             @map("max_jobs")
  maxApplicants     Int             @map("max_applicants")
  features          Json?
  amount            Decimal?
  currency          String?
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  company           CompanyProfile  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

model AnalyticsEvent {
  id                String          @id @default(uuid())
  userId            String?         @map("user_id")
  eventType         String          @map("event_type")
  eventData         Json            @map("event_data")
  ipAddress         String?         @map("ip_address")
  userAgent         String?         @map("user_agent")
  createdAt         DateTime        @default(now()) @map("created_at")

  user              User?           @relation(fields: [userId], references: [id])

  @@index([eventType, createdAt])
  @@map("analytics_events")
}

model Notification {
  id                String          @id @default(uuid())
  userId            String          @map("user_id")
  type              String
  title             String
  message           String          @db.Text
  link              String?
  isRead            Boolean         @default(false) @map("is_read")
  createdAt         DateTime        @default(now()) @map("created_at")

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
